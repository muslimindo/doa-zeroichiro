function autoResize(el){el.style.height="auto";el.style.height=Math.min(el.scrollHeight,120)+"px";}
function handleKey(e){if(e.key==="Enter"&&!e.shiftKey){e.preventDefault();searchAI();}}

// ===== AI SEARCH =====
async function searchAI(){
  const q=document.getElementById("aiInput").value.trim();
  if(!q)return;
  const btn=document.getElementById("aiBtn");
  btn.disabled=true;
  const res=document.getElementById("aiResult");

  res.innerHTML=`
    <div class="ai-result fade-in">
      <div class="ai-result-card">
        <div class="ai-result-header"><span class="ai-result-icon">✨</span><span class="ai-result-label">Mencari: "${q}"</span></div>
        <div class="ai-result-body"><div class="loading-dots"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div></div>
      </div>
    </div>`;

  const systemPrompt=`Kamu adalah ustadz digital yang ahli dalam Al-Qur'an dan Hadis. 
Ketika user mencari doa, bacaan, atau shalawat, berikan jawaban LENGKAP dalam format JSON berikut (array, bisa 1-5 item tergantung permintaan):

[
  {
    "title": "Nama doa/bacaan",
    "arabic": "Teks Arab lengkap",
    "latin": "Transliterasi latin dengan tanda baca panjang pendek",
    "indonesia": "Terjemahan bahasa Indonesia yang fasih",
    "source": "Sumber (contoh: QS. Al-Baqarah: 255 atau HR. Bukhari no. 6312)",
    "type": "quran atau hadis",
    "keterangan": "Penjelasan singkat kapan/bagaimana doa ini dibaca (1-2 kalimat)"
  }
]

Penting:
- Hanya JSON, tidak ada teks lain di luar JSON
- Teks Arab harus benar dan lengkap
- Latin menggunakan transliterasi akademik (ā, ī, ū, ḥ, dll)
- Jika tidak ditemukan, kembalikan array kosong []
- Maksimal 5 doa per pencarian`;

  try{
    const response=await fetch("https://api.anthropic.com/v1/messages",{
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body:JSON.stringify({
        model:"claude-sonnet-4-20250514",
        max_tokens:2000,
        system:systemPrompt,
        messages:[{role:"user",content:q}]
      })
    });
    const data=await response.json();
    const raw=data.content?.map(x=>x.text||"").join("");
    
    let items=[];
    try{
      const clean=raw.replace(/```json|```/g,"").trim();
      items=JSON.parse(clean);
    }catch{items=[];}

    if(!items||items.length===0){
      res.innerHTML=`
        <div class="ai-result fade-in">
          <div class="ai-result-card">
            <div class="ai-result-header"><span class="ai-result-icon">🔍</span><span class="ai-result-label">Hasil Pencarian AI</span></div>
            <div class="ai-result-body"><div class="ai-error">Doa tidak ditemukan. Coba kata kunci yang berbeda.</div></div>
          </div>
        </div>`;
    } else {
      let bodyHtml=items.map((d,i)=>`
        <div class="ai-multi-item">
          <div class="doa-title-ai">${i+1}. ${d.title||""}</div>
          <div class="doa-arabic">${d.arabic||""}</div>
          <div class="doa-latin">${d.latin||""}</div>
          <div class="sep"></div>
          <div class="doa-id">"${d.indonesia||""}"</div>
          ${d.keterangan?`<div style="font-size:12px;color:var(--text-d);margin-bottom:10px;font-style:italic;">📌 ${d.keterangan}</div>`:""}
          <span class="doa-source ${d.type==="quran"?"src-quran":"src-hadis"}">${d.type==="quran"?"📖":"📜"} ${d.source||""}</span>
        </div>`).join("");

      res.innerHTML=`
        <div class="ai-result fade-in">
          <div class="ai-result-card">
            <div class="ai-result-header"><span class="ai-result-icon">✨</span><span class="ai-result-label">Ditemukan ${items.length} hasil untuk "${q}"</span></div>
            <div class="ai-result-body">${bodyHtml}</div>
          </div>
        </div>`;
    }
    document.getElementById("aiInput").value="";
    document.getElementById("aiInput").style.height="auto";
  }catch(e){
    res.innerHTML=`
      <div class="ai-result fade-in">
        <div class="ai-result-card">
          <div class="ai-result-header"><span class="ai-result-icon">⚠</span><span class="ai-result-label">Terjadi Kesalahan</span></div>
          <div class="ai-result-body"><div class="ai-error">Gagal terhubung ke AI. Periksa koneksi internet kamu.</div></div>
        </div>
      </div>`;
  }
  btn.disabled=false;
}

// ===== LOCAL CARDS =====
function renderCards(){
  const q=document.getElementById("localSearch").value.trim().toLowerCase();
  let list=duas;
  if(showBm)list=list.filter(d=>bookmarks.includes(d.id));
  if(activeCat!=="semua")list=list.filter(d=>d.cat===activeCat);
  if(q)list=list.filter(d=>d.title.toLowerCase().includes(q)||d.id_text.toLowerCase().includes(q)||d.latin.toLowerCase().includes(q));

  const el=document.getElementById("content");
  if(!list.length){
    el.innerHTML=`<div class="section-lbl">${showBm?"★ Favorit (0)":"Koleksi Doa"}</div><div class="empty"><div class="empty-icon">🤲</div><div style="font-size:14px;font-style:italic;">${showBm?"Belum ada favorit":"Tidak ditemukan"}</div></div>`;
    return;
  }

  let html=`<div class="section-lbl">${showBm?"★ Favorit ("+list.length+")":"Koleksi Doa ("+list.length+")"}</div>`;
  list.forEach((d,i)=>{
    const isExp=expanded===d.id, isBm=bookmarks.includes(d.id);
    const words=d.arabic.split(" ");
    const prev=words.slice(0,6).join(" ")+(words.length>6?"…":"");
    html+=`
    <div class="card" style="animation-delay:${i*.03}s">
      <div class="card-hdr" onclick="toggleCard(${d.id})">
        <div class="card-left">
          <div class="card-title">${d.title}</div>
          <div class="arabic-prev">${isExp?d.arabic:prev}</div>
        </div>
        <div class="card-right">
          <button class="bm-btn${isBm?" saved":""}" onclick="event.stopPropagation();toggleBm(${d.id})">${isBm?"★":"☆"}</button>
          <span class="arrow${isExp?" open":""}">▾</span>
        </div>
      </div>
      <div class="card-body${isExp?" open":""}">
        <div class="gold-line"></div>
        <div class="doa-arabic">${d.arabic}</div>
        <div class="doa-latin">${d.latin}</div>
        <div class="sep"></div>
        <div class="doa-id">"${d.id_text}"</div>
        <span class="doa-source ${d.type==="quran"?"src-quran":"src-hadis"}">${d.type==="quran"?"📖":"📜"} ${d.source}</span>
      </div>
    </div>`;
  });
  el.innerHTML=html;
  document.getElementById("bmCount").textContent=bookmarks.length;
}

function toggleCard(id){expanded=expanded===id?null:id;renderCards();}

// Init
saveBm();
renderCards();
</script>
