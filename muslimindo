  {id:11,cat:"harian",title:"Doa Ketika Hujan",
   arabic:"اللَّهُمَّ صَيِّباً نَافِعاً",
   latin:"Allāhumma ṣayyiban nāfi'ā.",
   id_text:"Ya Allah, jadikanlah hujan ini hujan yang bermanfaat.",
