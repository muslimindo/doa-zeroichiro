  {id:"keluarga",label:"🌿 Keluarga"},
];

let activeCat="semua", bookmarks=[], showBm=false, expanded=null, darkMode=true;
try{ bookmarks=JSON.parse(localStorage.getItem("zi_bm")||"[]"); }catch{}

// Init tabs
const tabsEl=document.getElementById("tabs");
catList.forEach(c=>{
  const b=document.createElement("button");
  b.className="tab"+(c.id===activeCat?" active":"");
  b.textContent=c.label; b.id="tab-"+c.id;
  b.onclick=()=>{
    if(showBm){showBm=false;updateBmBtn();}
    activeCat=c.id;
    document.querySelectorAll(".tab").forEach(x=>x.classList.remove("active"));
    b.classList.add("active");
    renderCards();
  };
  tabsEl.appendChild(b);
});

function saveBm(){localStorage.setItem("zi_bm",JSON.stringify(bookmarks));document.getElementById("bmCount").textContent=bookmarks.length;}
function toggleBm(id){bookmarks.includes(id)?bookmarks=bookmarks.filter(x=>x!==id):bookmarks.push(id);saveBm();renderCards();}
function updateBmBtn(){const b=document.getElementById("bmToggle");b.classList.toggle("active",showBm);b.innerHTML=(showBm?"★":"☆")+' <span id="bmCount">'+bookmarks.length+'</span>';}
function toggleBmView(){showBm=!showBm;updateBmBtn();if(showBm){activeCat="semua";document.querySelectorAll(".tab").forEach(x=>x.classList.remove("active"));document.getElementById("tab-semua").classList.add("active");}renderCards();}

function toggleDark(){
  darkMode=!darkMode;
  const r=document.documentElement.style;
  if(!darkMode){
    r.setProperty("--bg","#f5f0e8");r.setProperty("--bg2","#ede7d5");r.setProperty("--bg3","#e0d8c5");
    r.setProperty("--text","#2a2010");r.setProperty("--text-d","#6a5a3a");
    r.setProperty("--border","rgba(100,70,20,0.2)");r.setProperty("--border-b","rgba(100,70,20,0.4)");
    r.setProperty("--cream","#2a1a08");r.setProperty("--gold","#8a5e10");r.setProperty("--gold-l","#6a4408");r.setProperty("--gold-d","#a07828");
    document.getElementById("darkBtn").textContent="🌙";
  }else{
    r.setProperty("--bg","#0a0a0a");r.setProperty("--bg2","#111");r.setProperty("--bg3","#1a1a1a");
